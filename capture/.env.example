# Which Knottra to feed. Deployed engine, or http://127.0.0.1:8000 for local.
KNOTTRA_BASE_URL=https://knottra-production.up.railway.app

# IMPORTANT: Knottra sessions are per-API-key. Use the SAME key Harbour.Wiki
# reads with (its KNOTTRA_API_KEY on Railway) — a mismatched key means the wiki
# gets a 403 and cannot display this lecture.
KNOTTRA_API_KEY=

# --- optional overrides ---
# WHISPER_MODEL=base.en          # tiny.en (fastest) | base.en | small.en (best)
# CHUNK_SECONDS=6                 # audio seconds per transcription/event
# WHISPER_LANGUAGE=en            # force a language; omit to autodetect
# AUDIO_DEVICE=                  # input device index (see: python -m sounddevice)
# KNOTTRA_DOMAIN_PROMPT=         # override the default lecture fusion guidance
