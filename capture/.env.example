# The recorder talks ONLY to Harbour.Wiki — never to Knottra directly. The app
# is the single gateway and holds the Knottra key server-side.

# Harbour.Wiki base URL (deployed, or http://127.0.0.1:3000 for local dev).
HARBOUR_WIKI_BASE_URL=https://harbour-wiki-production.up.railway.app

# Capture token — must match CAPTURE_TOKEN set on the Harbour.Wiki service.
# Leave empty only if the app's /api/ingest is left open (local dev).
CAPTURE_TOKEN=

# --- optional overrides ---
# WHISPER_MODEL=small.en         # tiny.en/base.en on a weak PC
# MAX_UTTERANCE_SECONDS=12       # forced cut; normally cuts at natural pauses
# MIN_CONFIDENCE=0.35            # don't send utterances below this confidence
# CAPTURE_CONTEXT=               # vocabulary hint (course terms) for Whisper
# WHISPER_LANGUAGE=en            # force a language; omit to autodetect
# AUDIO_DEVICE=                  # input device index (see: python -m sounddevice)
# CAPTURE_DOMAIN_PROMPT=         # override the default lecture fusion guidance
# CAMERA_DEVICE=0                # physical PTZ camera index
# CAMERA_SEND_INTERVAL_SECONDS=10
# CAMERA_LOST_DELAY_SECONDS=1.5
# CAMERA_PAN_SIGN=1              # set -1 if pan moves away from the lecturer
# CAMERA_TILT_SIGN=1             # set -1 if tilt moves away from the lecturer
# CAMERA_AUDIENCE_ZONES=0,0.62;1,0.62;1,1;0,1  # always-masked desk polygon(s separated by |)
# CAMERA_PRIVACY_MIN_CONFIDENCE=0.35
# LECTURE_OUTBOX_PATH=            # durable event queue (default ~/.lecture-capture/outbox.sqlite3)
# LECTURE_AUDIO_SPOOL_DIR=        # overflow WAV blocks (default ~/.lecture-capture/audio-spool)
# The automatic timetable itself lives in schedule.json; start from schedule.example.json.
