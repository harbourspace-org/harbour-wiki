# Knottra fusion engine (server-side only — never exposed to the browser).
# Use 127.0.0.1 (not localhost) to avoid Node fetch resolving to IPv6 ::1.
KNOTTRA_BASE_URL=http://127.0.0.1:8000
KNOTTRA_API_KEY=dev-key-change-me

# App-side Postgres for the human layer (courses, annotations, student links).
# Uses its own `harbour_wiki` schema; point at a dedicated DB in production.
APP_DATABASE_URL=postgresql://knottra:knottra@localhost:5432/knottra

# The app's own LLM for grounded answers (OpenAI-compatible; e.g. opencode.ai)
LLM_BASE_URL=https://opencode.ai/zen/v1
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
