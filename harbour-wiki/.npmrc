# Tailwind v4's oxide engine resolves its platform-native binary with a bare
# require('@tailwindcss/oxide-<platform>'). pnpm's default isolated node_modules
# hides that transitive optional package from the loader, so the Linux build
# fails with "Cannot find native binding". A hoisted (npm-style) layout makes
# the platform binary resolvable. See tailwindlabs/tailwindcss#... (pnpm + oxide).
node-linker=hoisted
